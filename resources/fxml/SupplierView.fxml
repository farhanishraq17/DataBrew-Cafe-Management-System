<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml" fx:controller="com.databrew.cafe.controller.SupplierController">
  <center>
    <SplitPane dividerPositions="0.62">
      <VBox spacing="12" SplitPane.resizableWithParent="true">
        <padding><Insets top="16" right="16" bottom="16" left="16" /></padding>
        <Label text="Suppliers" styleClass="section-title" />
        <TableView fx:id="supplierTable" VBox.vgrow="ALWAYS" fixedCellSize="44.0" styleClass="menu-table">
          <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colName" text="Name" prefWidth="180" />
            <TableColumn fx:id="colContact" text="Contact Person" prefWidth="160" />
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="140" />
            <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
          </columns>
          <placeholder><Label text="No suppliers" /></placeholder>
        </TableView>
      </VBox>

      <VBox spacing="14" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.2, 0, 4);">
        <Label text="Supplier Details" styleClass="section-title" />
        <GridPane hgap="14" vgap="14">
          <columnConstraints>
            <ColumnConstraints percentWidth="35" />
            <ColumnConstraints percentWidth="65" />
          </columnConstraints>
          <Label text="Name" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label" />
          <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="form-control" promptText="Supplier name" />
          <Label text="Contact Person" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label" />
          <TextField fx:id="contactField" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="form-control" promptText="Contact name" />
          <Label text="Phone" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label" />
          <TextField fx:id="phoneField" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="form-control" promptText="Phone number" />
          <Label text="Email" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label" />
          <TextField fx:id="emailField" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="form-control" promptText="Email address" />
        </GridPane>
        <Region VBox.vgrow="ALWAYS" />
        <HBox spacing="10" alignment="CENTER" styleClass="actions-bar">
          <Button text="Clear" onAction="#onClear" styleClass="btn-clear-strong" prefHeight="50" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
          <Button text="Add" onAction="#onAdd" styleClass="btn-primary-strong" prefHeight="50" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
          <Button text="Update" onAction="#onUpdateAction" styleClass="btn-primary-strong" prefHeight="50" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: linear-gradient(to right, #f59e0b, #d97706);" />
          <Button text="Remove" onAction="#onDelete" styleClass="btn-danger-strong" prefHeight="50" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
        </HBox>
      </VBox>
    </SplitPane>
  </center>
</BorderPane>
